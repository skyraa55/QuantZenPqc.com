# Copy this file to .env and fill in your real values. Never commit .env itself.

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/quantzen
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quantzen?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/quantzen

# Port the API server listens on
PORT=5000

# Comma-separated list of origins allowed to call this API.
# Vite's default dev server runs on 5173.
CLIENT_ORIGIN=http://localhost:5173
